# FastAPI
SECRET_KEY=change-me-to-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://devpunks:change-me-strong-password@postgres:5432/devpunks

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=devpunks_knowledge

# LLM — Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# LLM — OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM Provider (anthropic | openai)
LLM_PROVIDER=anthropic

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Voice — Vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Voice — ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.6

# SuperAdmin seed (first run only)
SUPERADMIN_EMAIL=admin@devpunks.io
SUPERADMIN_PASSWORD=change-me-on-first-login

# CORS
ALLOWED_ORIGINS=https://devpunks.io,https://admin.devpunks.io
